# Production env — copy to `.env` on the server and fill in real values.
#   cp .env.prod.example .env
# This single file is read twice: by docker-compose for ${VAR} interpolation
# (postgres/web/caddy) AND injected into the API container via env_file.
# Never commit the real `.env` (it is git- and docker-ignored).

# --- Deployment / TLS (Caddy) ---
# Bare apex domain; Caddy serves the canonical www.<DOMAIN> and 301s the apex.
DOMAIN=scs-firearms.com
ACME_EMAIL=admin@scs-firearms.com

# --- Postgres ---
POSTGRES_USER=armurier
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password
POSTGRES_DB=armurier_prod
# DATABASE_URL is set by docker-compose to point at the `postgres` service,
# so it is intentionally NOT defined here.

# --- JWT (generate each with: openssl rand -base64 48) ---
JWT_SECRET=CHANGE-ME-very-long-secret-min-32-chars
JWT_REFRESH_SECRET=CHANGE-ME-very-long-refresh-secret-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- Storage (S3-compatible; Scaleway in prod) ---
STORAGE_DRIVER=s3
S3_ENDPOINT=https://s3.fr-par.scw.cloud
S3_ACCESS_KEY=your-scw-access-key
S3_SECRET_KEY=your-scw-secret-key
S3_BUCKET=armurier-prod
S3_REGION=fr-par
S3_FORCE_PATH_STYLE=false

# --- SMTP (transactional email) ---
SMTP_HOST=mail.ovh.net
SMTP_PORT=587
SMTP_USER=noreply@scs-firearms.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@scs-firearms.com

# --- Stripe (live keys + webhook signing secret) ---
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# --- Bank transfer (virement) — account printed on the customer RIB ---
VIREMENT_IBAN=FR7630006000011234567890189
VIREMENT_BIC=AGRIFRPP
VIREMENT_BANK_NAME=Banque Exemple
VIREMENT_ACCOUNT_HOLDER=SCS Firearm SAS

# --- Admin seed (created by db:seed if absent) — CHANGE before first deploy ---
ADMIN_SEED_EMAIL=admin@scs-firearms.com
ADMIN_SEED_PASSWORD=CHANGE-ME-strong-admin-password

# --- Observability / scheduling ---
LOG_LEVEL=info
ERROR_ALERTS_ENABLED=true
ERROR_ALERT_COOLDOWN_MINUTES=15
SLA_CHECK_INTERVAL_MINUTES=60

# --- Business ---
COMMISSION_RATE_PCT=5

# Canonical public front URL (CORS origin + email links).
WEB_BASE_URL=https://www.scs-firearms.com
