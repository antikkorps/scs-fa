{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "minimumReleaseAge": "90 days",
  "prCreation": "not-pending",
  "vulnerabilityAlerts": {
    "minimumReleaseAge": "0 days",
    "labels": ["security"]
  },
  "customManagers": [
    {
      "description": "Keep the biome.json $schema URL in sync with the @biomejs/biome version",
      "customType": "regex",
      "managerFilePatterns": ["biome.json"],
      "matchStrings": ["https://biomejs\\.dev/schemas/(?<currentValue>[^/\"]+)/schema\\.json"],
      "depNameTemplate": "@biomejs/biome",
      "datasourceTemplate": "npm"
    }
  ],
  "packageRules": [
    {
      "description": "Group non-major npm updates into a single PR per ecosystem",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "npm non-major"
    },
    {
      "description": "Group devDependency major updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "matchDepTypes": ["devDependencies"],
      "groupName": "devDeps major"
    }
  ]
}
