# Database
DATABASE_URL=postgresql://armurier:armurier_dev_password@localhost:5435/armurier_dev

# JWT (generate with: openssl rand -base64 48)
JWT_SECRET=replace-me-with-a-very-long-secret-key-min-32-chars
JWT_REFRESH_SECRET=replace-me-with-a-very-long-refresh-secret-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# API
API_PORT=8081
API_HOST=0.0.0.0

# Storage (provider-agnostic). STORAGE_DRIVER: "s3" (default) or "memory" (tests/CI).
# S3 vars work for any S3-compatible provider (Scaleway, AWS, MinIO, ...).
# S3_FORCE_PATH_STYLE=true is required for MinIO and some self-hosted setups.
STORAGE_DRIVER=s3
S3_ENDPOINT=https://s3.fr-par.scw.cloud
S3_ACCESS_KEY=your-scw-access-key
S3_SECRET_KEY=your-scw-secret-key
S3_BUCKET=armurier-dev
S3_REGION=fr-par
S3_FORCE_PATH_STYLE=false

# SMTP
SMTP_HOST=mail.ovh.net
SMTP_PORT=587
SMTP_USER=noreply@armurier.fr
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@armurier.fr

# Stripe (card payments). Get keys from the Stripe dashboard; the webhook
# secret is shown when you register the endpoint (or via `stripe listen`).
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Bank transfer (virement). The SCS receiving account shown to customers on the
# RIB for regulated-firearm orders. Snapshotted onto each order at creation.
VIREMENT_IBAN=FR7630006000011234567890189
VIREMENT_BIC=AGRIFRPP
VIREMENT_BANK_NAME=Banque Exemple
VIREMENT_ACCOUNT_HOLDER=SCS Firearm SAS

# Admin seed (Story 7.1 backoffice). The seed creates this admin if absent so the
# /admin dashboard is usable immediately. CHANGE THESE outside local dev.
ADMIN_SEED_EMAIL=admin@scs-firearm.local
ADMIN_SEED_PASSWORD=AdminSCS-ChangeMe-2026!

# Observability (Story 7.2). LOG_LEVEL overrides the per-env default (silent in
# test, info in prod, debug locally). Server errors (5xx) email admins, throttled
# per error signature; alerts are off outside production unless enabled here.
# LOG_LEVEL=info
ERROR_ALERT_COOLDOWN_MINUTES=15
# ERROR_ALERTS_ENABLED=false

# Node
NODE_ENV=development
