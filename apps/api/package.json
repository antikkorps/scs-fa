{
  "name": "@armurier/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:drop": "drizzle-kit drop",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed-cli.ts"
  },
  "dependencies": {
    "@armurier/shared": "workspace:*",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/jwt": "10.0.0",
    "@fastify/rate-limit": "10.3.0",
    "@node-rs/argon2": "2.0.2",
    "dotenv": "17.2.4",
    "drizzle-orm": "0.45.1",
    "fastify": "5.7.4",
    "pg": "8.18.0",
    "pino-pretty": "13.1.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.10.13",
    "@types/pg": "8.16.0",
    "@vitest/coverage-v8": "4.0.18",
    "drizzle-kit": "0.31.9",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
